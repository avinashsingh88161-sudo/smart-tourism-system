<% layout('layouts/boilerplate') %> 

   <!-- <h3>All Listings </h3> -->
   
<!--<form action="/listings/new" method="GET">
       <button>create new listing</button>
    </form>-->
<style>
  #filters{
    display: flex;
    flex-wrap: wrap;
    align-items: center;
  }
  .filter{
    text-align: center;
    margin-right: 2rem;
    margin-top: 2rem;
    cursor: pointer;
    opacity: 0.7;
  }
  .filter:hover{
    opacity: 1;
    cursor: pointer;
  }
  .filter p{
    font-size: .8rem;
  }
  .tax-info{
    display: none;
  }
  .text-toggle{
    border: 1px solid black;
    border-radius: 1rem;
    height: 3rem ;
    padding:1rem ;
    margin-left: 5rem;
    display: flex;
    align-items: center;
  }
</style>


 <div id="filters">
  <div class="filter">
   <div> <i class="fa-solid fa-fire"></i></div>
   <p>Trending</p>
  </div>
    <div class="filter">
   <div> <i class="fa-solid fa-bed"></i></div>
   <p>Bed & Breakfast</p>
  </div>
    <div class="filter">
   <div> <i class="fa-solid fa-mountain-city"></i></div>
   <p>Iconic city</p>
  </div>
    <div class="filter">
   <div><i class="fa-solid fa-mountain"></i></div>
   <p>Mountains</p>
  </div>
     <div class="filter">
   <div><i class="fa-brands fa-fort-awesome"></i></div>
   <p>Castle</p>
  </div>
   <div class="filter">
   <div><i class="fa-solid fa-person-swimming"></i></div>
   <p>Amazing pool</p>
  </div>
     <div class="filter">
   <div><i class="fa-solid fa-campground"></i></div>
   <p>Campground</p>
  </div>
    <div class="filter">
   <div><i class="fa-solid fa-tractor"></i></div>
   <p>Farm stay</p>
  </div>
   <div class="filter">
   <div><i class="fa-regular fa-snowflake"></i></div>
   <p>Arctic</p>
  </div>
    <div class="filter">
   <div><i class="fa-solid fa-igloo"></i></div>
   <p>Doms</p>
  </div>
   <div class="filter">
   <div><i class="fa-solid fa-sailboat"></i></div>
   <p>Boats</p>
  </div>

  <div class="text-toggle">
    <div class="form-check-reverse form-switch">
  <input class="form-check-input" type="checkbox" role="switch" id="switchCheckDefault">
  <label class="form-check-label" for="switchCheckDefault">Display taxes</label>
</div>
  </div>
 </div>

<div class="row row-cols-lg-4 row-cols-md-3 row-cols-sm-2 g-3  ">
  <% for(let listing of allListings){ %>
  <div class="col">
    <a href="/listings/<%= listing._id %>" style="text-decoration: none; color: black;" class="listing-link">
      <div class="card h-100 listing-card">
        <img 
          src="<%= listing.image.url || listing.image %>" 
          class="card-img-top" 
          style="height: 20rem;">
           <div class="card-img-overlay"></div>

        <div class="card-body">
          <h5><%= listing.title %></h5>
          <p>₹ <%= listing.price.toLocaleString("en-IN") %>/night        <i class="tax-info">&nbsp; +18% GST</i></p>
        </div>
      </div>
    </a>
  </div>
  <% } %>
</div>  


<script>
  let taxSwitch=document.getElementById('switchCheckDefault');
  taxSwitch.addEventListener("click",()=>{
    console.log("clicked");
    let taxInfo=document.getElementsByClassName("tax-info");
   for(info of taxInfo){
    if(info.style.display!="inline"){
      info.style.display="inline";
    }else{
      info.style.display="none";
    }
   }
  })

</script>