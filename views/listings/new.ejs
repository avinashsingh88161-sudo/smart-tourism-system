<% layout('layouts/boilerplate') %>

<div class="row mt-3">
  <div class="col-8 offset-2">
    <h3><b>Create New Listing</b></h3>

    <form method="POST" action="/listings" novalidate class="needs-validation" enctype="multipart/form-data">
      <div class="mb-3">
        <label class="form-label" for="title">Title</label>
        <input
          name="listing[title]"
          type="text"
          placeholder="Enter title"
          class="form-control"
          required
        />
        <div class="valid-feedback">Title looks good</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Description</label>
        <textarea
          name="listing[description]"
          class="form-control"
          required
        ></textarea>
        <div class="invalid-feedback">enter short description </div>  
      </div>

      <div class="mb-3">
        <label class="form-label">Upload Image</label>
        <input
          name="listing[image]"
          type="file"
          class="form-control"
          required
        />
      </div>

      <div class="mb-3">
        <label class="form-label">Price</label>
        <input name="listing[price]" class="form-control" required placeholder="Enter price" />
        <div class="invalid-feedback"> enter price should be valid</div>
      </div>

      <div class="mb-3">
        <label class="form-label" placeholder="india">Location</label>
        <input
          name="listing[location]"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">enter location should be valid</div>
      </div>

      <div class="mb-3">
        <label class="form-label">Country</label>
        <input
          name="listing[country]"
          type="text"
          class="form-control"
          required
        />
        <div class="invalid-feedback">enter country should be valid</div>
      </div>

      <button class="btn btn-dark add-btn">Add Listing</button><br /><br />
    </form>
  </div>
</div>
