<% layout('layouts/boilerplate') %>

<% if (!listing) { %>
  <div class="container mt-4">
    <div class="alert alert-danger">
      <h4>Error: Listing not found</h4>
      <p>The listing you're looking for doesn't exist or has been removed.</p>
      <a href="/listings" class="btn btn-primary">Go to Listings</a>
    </div>
  </div>
<% } else { %>

<div class="container mt-4">

  <!-- TITLE -->
  <div class="text-center mb-3">
    <h3>Listings Details</h3>
  </div>

  <!-- CARD CENTER -->
  <div class="row justify-content-center">
    <div class="col-md-6">

      <div class="card show-card listing-card">

        <img
          src="<%= listing.image.url || listing.image %>"
          class="card-img-top show-image"
          style="height:300px; object-fit:cover;"
          alt="<%= listing.title %>"
        />

        <div class="card-body">
          <div class="card-text text-card mb-2">
            <strong>Owner:</strong>
            <% if(listing.owner && listing.owner.username){ %>
              <%= listing.owner.username %>
            <% } else { %>
              No Owner
            <% } %>
          </div>
          <div class="card-text text-card mb-2">
            <strong><%= listing.title %></strong>
          </div>
          <div class="card-text text-card mb-2"><%= listing.description %></div>
          <div class="card-text text-card mb-2">&#8377;<%= listing.price.toLocaleString("en-IN") %></div>
          <div class="card-text text-card mb-2"><%= listing.country %></div>
          <div class="card-text text-card"><%= listing.location %></div>
        </div>

      </div>

    </div>
  </div>
  <br>

  <!--  FIXED BUTTONS SECTION -->
  <% if(currentUser && listing.owner && currentUser._id.equals(listing.owner._id)) { %>
  <div class="d-flex justify-content-center gap-3 mt-4">
    <a href="/listings/<%= listing._id %>/edit" class="btn btn-dark">
      <i class="fas fa-edit"></i> Edit
    </a>

    <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST" style="display: inline;">
      <button type="submit" class="btn btn-danger" 
              onclick="return confirm('Are you sure you want to delete this listing?')">
        <i class="fas fa-trash"></i> Delete
      </button>
    </form>
  </div>
  <% } %>

  <!-- REVIEW FORM -->
  <div class="row justify-content-center mt-4">
    <div class="col-md-6">
      <hr />
      <% if(currentUser){ %>
      <h4 class="text-center">Leave a Review</h4>

      <form action="/listings/<%= listing._id %>/reviews" method="POST" class="needs-validation" novalidate>

        <div class="mb-3">
          <fieldset class="starability-slot">
            <legend>Rating:</legend>
            <input type="radio" id="rate1" name="review[rating]" value="1" required />
            <label for="rate1" title="Terrible">1 star</label>
            <input type="radio" id="rate2" name="review[rating]" value="2" />
            <label for="rate2" title="Not good">2 stars</label>
            <input type="radio" id="rate3" name="review[rating]" value="3" />
            <label for="rate3" title="Average">3 stars</label>
            <input type="radio" id="rate4" name="review[rating]" value="4" />
            <label for="rate4" title="Very good">4 stars</label>
            <input type="radio" id="rate5" name="review[rating]" value="5" />
            <label for="rate5" title="Amazing">5 stars</label>
            <div class="invalid-feedback">Please select a rating.</div>
          </fieldset>
        </div>
       
        <div class="mb-3">
          <label for="reviewComment" class="form-label">Comments:</label>
          <textarea id="reviewComment" name="review[comment]" class="form-control" rows="4" required></textarea>
          <div class="invalid-feedback">Please provide a comment.</div>
        </div>

        <button type="submit" class="btn btn-outline-dark">Submit Review</button>

      </form>
      <% } else { %>
        <p class="text-center text-muted">🔐 <a href="/login">Login</a> to leave a review</p>
      <% } %>
    </div>
  </div>

  <!-- REVIEWS -->
  <div class="row justify-content-center mt-2 col-md-12">
    <div class="col-md-6">
      <h5 class="text-center">All Reviews (<%= listing.reviews.length %>)</h5>

      <% if(listing.reviews && listing.reviews.length > 0) { %>
        <% for(review of listing.reviews){ %>
          <div class="card mb-3">
            <div class="card-body">
              <h6 class="card-title">@
                <% if(review.author && review.author.username) { %>
                  <%= review.author.username %>
                <% } else { %>
                  Anonymous
                <% } %>
              </h6>
              <div class="starability-result card-text mb-2" data-rating="<%= review.rating %>"></div>
              <p class="card-text"><%= review.comment %></p>
              
        

              <% if(currentUser && review.author && currentUser._id.equals(review.author._id)) { %>
                <form action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE" 
                      method="POST" style="display: inline;" 
                      onsubmit="return confirm('Delete this review?')">
                  <button class="btn btn-sm btn-danger">Delete</button>
                </form>
              <% } %>
            </div>
          </div>

        <% } %>
      <% } else { %>
        <p class="text-center text-muted mt-3">No reviews yet. Be the first to review! ⭐</p>
      <% } %>
    </div>
  </div>
</div>
<% } %>

